{
  "name": "auto-research-skill",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "clean": "rimraf public",
    "build:site": "node scripts/build.mjs",
    "build:css": "tailwindcss -c tailwind.config.mjs -i ./src/styles/input.css -o ./public/assets/site.css --minify",
    "build": "pnpm run clean && pnpm run build:site && pnpm run build:css && pnpm run validate",
    "validate": "node scripts/validate.mjs",
    "dev": "node scripts/dev.mjs",
    "new:article": "node scripts/new-article.mjs"
  },
  "devDependencies": {
    "daisyui": "^4.12.24",
    "png-to-ico": "^3.0.1",
    "rimraf": "^6.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17"
  }
}
